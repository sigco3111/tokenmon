#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

repo=""
sparkle_private_key_file=""
sparkle_public_key=""
csc_link=""
csc_link_file=""
csc_key_password="${CSC_KEY_PASSWORD:-}"
apple_api_key="${APPLE_API_KEY:-}"
apple_api_key_file=""
apple_api_key_id="${APPLE_API_KEY_ID:-}"
apple_api_issuer="${APPLE_API_ISSUER:-}"
apple_id="${APPLE_ID:-}"
apple_id_password="${APPLE_ID_PASSWORD:-}"
apple_team_id="${APPLE_TEAM_ID:-}"
homebrew_tap_repository="${HOMEBREW_TAP_REPOSITORY:-}"
dry_run="no"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/configure-github-release [options]

Options:
  --repo <owner/name>                 GitHub repo to configure. Defaults to Packaging/Tokenmon-Info.plist.
  --sparkle-private-key-file <path>   Sparkle private key file generated by ./scripts/generate-sparkle-keys.
  --sparkle-public-key <base64>       Optional explicit Sparkle public key. Derived from the private key file when omitted.
  --csc-link <value>                  Existing CSC_LINK secret value.
  --csc-link-file <path>              Path to a signing certificate .p12 file; the script base64-encodes it for CSC_LINK.
  --csc-key-password <value>          CSC_KEY_PASSWORD secret value. Falls back to the current environment variable.
  --apple-api-key-file <path>         Path to the App Store Connect API key .p8 file.
  --apple-api-key-id <value>          APPLE_API_KEY_ID secret value. Falls back to the current environment variable.
  --apple-api-issuer <value>          APPLE_API_ISSUER secret value. Falls back to the current environment variable.
  --apple-id <value>                  APPLE_ID secret value. Falls back to the current environment variable.
  --apple-id-password <value>         APPLE_ID_PASSWORD secret value. Falls back to the current environment variable.
  --apple-team-id <value>             APPLE_TEAM_ID secret value. Falls back to the current environment variable.
  --homebrew-tap-repo <owner/name>    Optional HOMEBREW_TAP_REPOSITORY variable value.
  --dry-run                           Print the repo secrets/variables that would be updated without calling gh.
  -h, --help                          Show this help.

Examples:
  ./scripts/configure-github-release \
    --sparkle-private-key-file ~/.config/tokenmon/sparkle-private-key.txt \
    --csc-link-file ~/certs/tokenmon.p12 \
    --csc-key-password "$CSC_KEY_PASSWORD" \
    --apple-api-key-file ~/keys/AuthKey_ABCDE12345.p8 \
    --apple-api-key-id "$APPLE_API_KEY_ID" \
    --apple-api-issuer "$APPLE_API_ISSUER"

  ./scripts/configure-github-release \
    --sparkle-private-key-file ~/.config/tokenmon/sparkle-private-key.txt \
    --dry-run
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      shift
      repo="${1:-}"
      ;;
    --sparkle-private-key-file)
      shift
      sparkle_private_key_file="${1:-}"
      ;;
    --sparkle-public-key)
      shift
      sparkle_public_key="${1:-}"
      ;;
    --csc-link)
      shift
      csc_link="${1:-}"
      ;;
    --csc-link-file)
      shift
      csc_link_file="${1:-}"
      ;;
    --csc-key-password)
      shift
      csc_key_password="${1:-}"
      ;;
    --apple-api-key-file)
      shift
      apple_api_key_file="${1:-}"
      ;;
    --apple-api-key-id)
      shift
      apple_api_key_id="${1:-}"
      ;;
    --apple-api-issuer)
      shift
      apple_api_issuer="${1:-}"
      ;;
    --apple-id)
      shift
      apple_id="${1:-}"
      ;;
    --apple-id-password)
      shift
      apple_id_password="${1:-}"
      ;;
    --apple-team-id)
      shift
      apple_team_id="${1:-}"
      ;;
    --homebrew-tap-repo)
      shift
      homebrew_tap_repository="${1:-}"
      ;;
    --dry-run)
      dry_run="yes"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unsupported argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift || true
done

resolve_repo() {
  if [[ -n "$repo" ]]; then
    printf '%s\n' "$repo"
    return
  fi

  /usr/libexec/PlistBuddy -c 'Print :TokenmonGitHubRepository' "$ROOT/Packaging/Tokenmon-Info.plist"
}

read_trimmed_file() {
  local path="$1"
  [[ -f "$path" ]] || { printf 'Missing file: %s\n' "$path" >&2; exit 1; }
  python3 - "$path" <<'PY'
import pathlib
import sys
print(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").strip())
PY
}

read_raw_file() {
  local path="$1"
  [[ -f "$path" ]] || { printf 'Missing file: %s\n' "$path" >&2; exit 1; }
  cat "$path"
}

base64_encode_file() {
  local path="$1"
  [[ -f "$path" ]] || { printf 'Missing file: %s\n' "$path" >&2; exit 1; }
  base64 < "$path" | tr -d '\n'
}

derive_public_key() {
  local private_key_base64="$1"
  swift - "$private_key_base64" <<'SWIFT'
import CryptoKit
import Foundation

let privateKeyBase64 = CommandLine.arguments[1]
guard let rawPrivateKey = Data(base64Encoded: privateKeyBase64) else {
    fputs("Invalid Sparkle private key base64.\n", stderr)
    exit(1)
}

do {
    let privateKey = try Curve25519.Signing.PrivateKey(rawRepresentation: rawPrivateKey)
    print(Data(privateKey.publicKey.rawRepresentation).base64EncodedString())
} catch {
    fputs("Failed to derive Sparkle public key: \(error)\n", stderr)
    exit(1)
}
SWIFT
}

require_gh() {
  command -v gh >/dev/null 2>&1 || {
    printf 'gh CLI is required\n' >&2
    exit 1
  }
  gh auth status >/dev/null 2>&1 || {
    printf 'gh CLI must be authenticated before configuring repo secrets\n' >&2
    exit 1
  }
}

declare -a variable_specs
declare -a secret_specs

append_variable() {
  local name="$1"
  local value="$2"
  variable_specs+=("${name}"$'\t'"${value}")
}

append_secret() {
  local name="$1"
  local value="$2"
  secret_specs+=("${name}"$'\t'"${value}")
}

set_gh_variable() {
  local repo_name="$1"
  local name="$2"
  local value="$3"
  if [[ "$dry_run" == "yes" ]]; then
    printf 'dry_run_variable repo=%s name=%s value=%s\n' "$repo_name" "$name" "$value"
    return
  fi

  gh variable set "$name" --repo "$repo_name" --body "$value" >/dev/null
  printf 'configured_variable repo=%s name=%s\n' "$repo_name" "$name"
}

set_gh_secret() {
  local repo_name="$1"
  local name="$2"
  local value="$3"
  if [[ "$dry_run" == "yes" ]]; then
    printf 'dry_run_secret repo=%s name=%s bytes=%s\n' "$repo_name" "$name" "${#value}"
    return
  fi

  gh secret set "$name" --repo "$repo_name" --body "$value" >/dev/null
  printf 'configured_secret repo=%s name=%s\n' "$repo_name" "$name"
}

repo="$(resolve_repo)"
[[ "$repo" == */* ]] || { printf 'Repository must be in owner/name form: %s\n' "$repo" >&2; exit 1; }

if [[ -n "$sparkle_private_key_file" ]]; then
  sparkle_private_key="$(read_trimmed_file "$sparkle_private_key_file")"
  [[ -n "$sparkle_private_key" ]] || { printf 'Sparkle private key file is empty: %s\n' "$sparkle_private_key_file" >&2; exit 1; }
  if [[ -z "$sparkle_public_key" ]]; then
    sparkle_public_key="$(derive_public_key "$sparkle_private_key")"
  fi
  append_secret "SPARKLE_ED_PRIVATE_KEY" "$sparkle_private_key"
fi

if [[ -n "$sparkle_public_key" ]]; then
  append_variable "SPARKLE_PUBLIC_ED_KEY" "$sparkle_public_key"
fi

if [[ -n "$csc_link" && -n "$csc_link_file" ]]; then
  printf 'Use either --csc-link or --csc-link-file, not both.\n' >&2
  exit 1
fi

if [[ -n "$csc_link_file" ]]; then
  csc_link="$(base64_encode_file "$csc_link_file")"
fi

if [[ -n "$csc_link" ]]; then
  append_secret "CSC_LINK" "$csc_link"
fi

if [[ -n "$csc_key_password" ]]; then
  append_secret "CSC_KEY_PASSWORD" "$csc_key_password"
fi

if [[ -n "$apple_api_key" && -n "$apple_api_key_file" ]]; then
  printf 'Use either APPLE_API_KEY in the environment or --apple-api-key-file, not both.\n' >&2
  exit 1
fi

if [[ -n "$apple_api_key_file" ]]; then
  apple_api_key="$(read_raw_file "$apple_api_key_file")"
fi

if [[ -n "$apple_api_key" || -n "$apple_api_key_id" || -n "$apple_api_issuer" ]]; then
  [[ -n "$apple_api_key" ]] || { printf 'Missing APPLE_API_KEY content.\n' >&2; exit 1; }
  [[ -n "$apple_api_key_id" ]] || { printf 'Missing APPLE_API_KEY_ID.\n' >&2; exit 1; }
  [[ -n "$apple_api_issuer" ]] || { printf 'Missing APPLE_API_ISSUER.\n' >&2; exit 1; }
  append_secret "APPLE_API_KEY" "$apple_api_key"
  append_secret "APPLE_API_KEY_ID" "$apple_api_key_id"
  append_secret "APPLE_API_ISSUER" "$apple_api_issuer"
fi

if [[ -n "$apple_id" || -n "$apple_id_password" || -n "$apple_team_id" ]]; then
  [[ -n "$apple_id" ]] || { printf 'Missing APPLE_ID.\n' >&2; exit 1; }
  [[ -n "$apple_id_password" ]] || { printf 'Missing APPLE_ID_PASSWORD.\n' >&2; exit 1; }
  [[ -n "$apple_team_id" ]] || { printf 'Missing APPLE_TEAM_ID.\n' >&2; exit 1; }
  append_secret "APPLE_ID" "$apple_id"
  append_secret "APPLE_ID_PASSWORD" "$apple_id_password"
  append_secret "APPLE_TEAM_ID" "$apple_team_id"
fi

if [[ -n "$homebrew_tap_repository" ]]; then
  append_variable "HOMEBREW_TAP_REPOSITORY" "$homebrew_tap_repository"
fi

if [[ "${#variable_specs[@]}" -eq 0 && "${#secret_specs[@]}" -eq 0 ]]; then
  printf 'Nothing to configure. Provide at least one release input.\n' >&2
  exit 1
fi

if [[ "$dry_run" != "yes" ]]; then
  require_gh
fi

printf 'repo=%s\n' "$repo"
printf 'dry_run=%s\n' "$dry_run"

for spec in "${variable_specs[@]}"; do
  IFS=$'\t' read -r name value <<< "$spec"
  set_gh_variable "$repo" "$name" "$value"
done

for spec in "${secret_specs[@]}"; do
  IFS=$'\t' read -r name value <<< "$spec"
  set_gh_secret "$repo" "$name" "$value"
done

printf 'configuration_complete=yes\n'
