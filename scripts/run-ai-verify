#!/usr/bin/env bash
set -euo pipefail

if [[ "\${1:-}" == "auth" && "\${2:-}" == "status" ]]; then
  exit 0
fi

if [[ "\${1:-}" == "variable" && "\${2:-}" == "get" && "\${3:-}" == "SPARKLE_PUBLIC_ED_KEY" ]]; then
  printf '%s\n' "\${TOKENMON_FAKE_GH_SPARKLE_KEY:-}"
  exit 0
fi

if [[ "\${1:-}" == "api" ]]; then
  for arg in "\$@"; do
    if [[ "\$arg" == "repos/$public_release_repo/releases/generate-notes" ]]; then
      cat <<EOF
{"name":"Tokenmon \${TOKENMON_FAKE_GH_RELEASE_TAG:-v0.0.0}","body":"## What's Changed\n\n- Added automated README media capture.\n- Unified release notes for GitHub and Sparkle.\n\n## Full Changelog\n\n- https://github.com/$public_release_repo/compare/\${TOKENMON_FAKE_GH_PREVIOUS_TAG:-v0.0.0}...\${TOKENMON_FAKE_GH_RELEASE_TAG:-v0.0.0}"}
EOF
      exit 0
    fi
  done
fi

printf 'unexpected fake gh invocation: %s\n' "\$*" >&2
exit 1
EOF_FAKE_GH
