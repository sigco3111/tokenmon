#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

worker_tag="${OMX_TEAM_WORKER:-manual}"
worker_tag="${worker_tag//\//-}"
scratch_root_default="$ROOT/.build/verify-$worker_tag"
scratch_path="${TOKENMON_VERIFY_SCRATCH_PATH:-$scratch_root_default}"
if [[ "${TOKENMON_VERIFY_UNIQUE_SCRATCH:-0}" == "1" ]]; then
  scratch_path="$scratch_path-$$"
fi
tokenmon_app_bin=""
include_release_tooling=0
include_readme_screenshots=0
timing_report="${TOKENMON_TIMING_REPORT:-}"

timing_now() {
  python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
}

record_timing() {
  local category="$1"
  local step="$2"
  local started_at="$3"
  local ended_at
  local duration

  ended_at="$(timing_now)"
  duration="$(python3 - "$started_at" "$ended_at" <<'PY'
import sys
start = float(sys.argv[1])
end = float(sys.argv[2])
print(f"{end - start:.3f}")
PY
)"

  printf 'TIMING: category=%s step=%s duration_seconds=%s\n' "$category" "$step" "$duration"
  if [[ -n "$timing_report" ]]; then
    printf 'category=%s step=%s duration_seconds=%s\n' "$category" "$step" "$duration" >>"$timing_report"
  fi
}

usage() {
  cat <<'EOF'
Usage:
  ./scripts/run-ai-verify [--include-release-tooling] [--include-readme-screenshots] [--timing-report <path>]

Options:
  --include-release-tooling   Run release-archive, Homebrew cask, Sparkle appcast, and tap-sync dry runs.
  --include-readme-screenshots
                              Generate README PNG and GIF media after the core verification lane.
  --timing-report <path>      Append machine-readable timing summary lines to the given file.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --include-release-tooling)
      include_release_tooling=1
      ;;
    --include-readme-screenshots)
      include_readme_screenshots=1
      ;;
    --timing-report)
      shift
      timing_report="${1:-}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unsupported argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift || true
done

swift_cmd() {
  local action="$1"
  shift
  local developer_dir="${DEVELOPER_DIR:-}"
  if [[ -z "$developer_dir" && -n "${MD_APPLE_SDK_ROOT:-}" ]]; then
    developer_dir="${MD_APPLE_SDK_ROOT}/Contents/Developer"
  fi
  if [[ -n "$developer_dir" && ! -d "$developer_dir" ]]; then
    developer_dir=""
  fi
  if [[ "$(uname -s)" == "Darwin" ]] && command -v xcrun >/dev/null 2>&1; then
    if [[ -n "$developer_dir" ]]; then
      DEVELOPER_DIR="$developer_dir" xcrun swift "$action" --scratch-path "$scratch_path" "$@"
    else
      xcrun swift "$action" --scratch-path "$scratch_path" "$@"
    fi
    return
  fi
  swift "$action" --scratch-path "$scratch_path" "$@"
}

tokenmon_app_cmd() {
  if [[ -z "$tokenmon_app_bin" ]]; then
    printf 'VERIFY FAIL: tokenmon_app_bin is not initialized\n' >&2
    exit 1
  fi
  "$tokenmon_app_bin" "$@"
}

require_contains() {
  local haystack="$1"
  local needle="$2"
  if [[ "$haystack" != *"$needle"* ]]; then
    printf 'VERIFY FAIL: expected output to contain %s\n' "$needle" >&2
    exit 1
  fi
}

have_repo_paths() {
  local relative_path
  for relative_path in "$@"; do
    [[ -e "$ROOT/$relative_path" ]] || return 1
  done
  return 0
}

public_release_repo="$("$ROOT/scripts/tokenmon-release-targets" repository)"
public_release_feed_url="$("$ROOT/scripts/tokenmon-release-targets" default-feed-url "$public_release_repo")"
has_species_art_tooling=0
has_repo_workflow_tooling=0
has_public_export_tooling=0
has_marketing_tooling=0

if have_repo_paths \
  "scripts/sync-species-art-manifest" \
  "scripts/build-species-animation-assets" \
  "scripts/render-species-contact-sheets" \
  "art/source" \
  "assets/sprites/species"
then
  has_species_art_tooling=1
fi

if have_repo_paths \
  "scripts/audit-codex-global-setup" \
  "scripts/tokenmon-codex-workflow-status" \
  "scripts/tokenmon-dev-workflow" \
  "scripts/repair-codex-global-setup" \
  ".codex/hooks/stop_verify_reminder.sh" \
  ".agents/skills"
then
  has_repo_workflow_tooling=1
fi

if have_repo_paths \
  "scripts/export-public-repo" \
  "scripts/audit-public-export" \
  "PublicExport/include-paths.txt" \
  "PublicExport/overlay/README.md"
then
  has_public_export_tooling=1
fi

if have_repo_paths \
  "scripts/tokenmon-marketing-team" \
  "marketing/README.md" \
  "marketing/prompts/daily-cmo-pack.md" \
  "marketing/positioning.md" \
  "marketing/channel-rules.md" \
  "marketing/guardrails.md" \
  "docs/development/marketing-team-harness.md"
then
  has_marketing_tooling=1
fi

require_any_contains() {
  local haystack="$1"
  shift

  local needle
  for needle in "$@"; do
    if [[ "$haystack" == *"$needle"* ]]; then
      return 0
    fi
  done

  printf 'VERIFY FAIL: expected output to contain one of: %s\n' "$*" >&2
  exit 1
}

require_integer_at_least() {
  local value="$1"
  local minimum="$2"
  local label="$3"
  if [[ "$value" =~ ^[0-9]+$ ]] && (( value >= minimum )); then
    return 0
  fi

  printf 'VERIFY FAIL: expected %s >= %s but got %s\n' "$label" "$minimum" "$value" >&2
  exit 1
}

probe_value() {
  local probe_output="$1"
  local key="$2"
  printf '%s\n' "$probe_output" | awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1) }'
}

probe_cli_lane() {
  local database_path="$1"
  python3 - "$database_path" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
db = sqlite3.connect(db_path)
cur = db.cursor()

row = cur.execute(
    """
    SELECT total_normalized_tokens,
           tokens_since_last_encounter,
           next_encounter_threshold_tokens,
           total_encounters,
           total_captures
    FROM exploration_state
    WHERE exploration_state_id = 1;
    """
).fetchone()

if row is None:
    row = (0, 0, 0, 0, 0)

recent_encounters = cur.execute("SELECT COUNT(*) FROM encounters;").fetchone()[0]
dex_seen_entries = cur.execute("SELECT COUNT(*) FROM dex_seen;").fetchone()[0]
dex_captured_entries = cur.execute("SELECT COUNT(*) FROM dex_captured;").fetchone()[0]

labels = (
    "total_normalized_tokens",
    "tokens_since_last_encounter",
    "next_encounter_threshold_tokens",
    "total_encounters",
    "total_captures",
)

for label, value in zip(labels, row):
    print(f"{label}={value}")

print(f"tokens_until_next_encounter={max(0, row[2] - row[1])}")

print(f"recent_encounters={recent_encounters}")
print(f"dex_seen_entries={dex_seen_entries}")
print(f"dex_captured_entries={dex_captured_entries}")
PY
}

probe_ingest_source() {
  local database_path="$1"
  local source_key="$2"
  python3 - "$database_path" "$source_key" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
source_key = sys.argv[2]
db = sqlite3.connect(db_path)
cur = db.cursor()

row = cur.execute(
    """
    SELECT last_offset,
           last_line_number,
           COALESCE(last_event_fingerprint, '')
    FROM ingest_sources
    WHERE source_key = ?
    LIMIT 1;
    """,
    (source_key,),
).fetchone()

if row is None:
    print("source_found=0")
    sys.exit(0)

print("source_found=1")
print(f"last_offset={row[0]}")
print(f"last_line_number={row[1]}")
print(f"last_event_fingerprint={row[2]}")
PY
}

probe_encounter_lane() {
  local database_path="$1"
  local expected_threshold_count="$2"
  python3 - "$database_path" "$expected_threshold_count" <<'PY'
import json
import math
import sqlite3
import sys

db_path = sys.argv[1]
expected_threshold_count = int(sys.argv[2])

db = sqlite3.connect(db_path)
cur = db.cursor()

expected_probabilities = {
    "common": 0.88,
    "uncommon": 0.68,
    "rare": 0.36,
    "epic": 0.16,
    "legendary": 0.06,
}

encounters = cur.execute(
    """
    SELECT encounter_id,
           encounter_sequence,
           threshold_event_index,
           species_id,
           field_code,
           rarity_tier,
           capture_probability,
           capture_roll,
           outcome
    FROM encounters
    ORDER BY encounter_sequence ASC;
    """
).fetchall()
encounter_count = len(encounters)
encounter_by_id = {row[0]: row for row in encounters}
encounter_species = {row[3] for row in encounters}
captured_species = {row[3] for row in encounters if row[8] == "captured"}
captured_count = sum(1 for row in encounters if row[8] == "captured")

dex_seen_rows = cur.execute(
    "SELECT species_id, last_encounter_id FROM dex_seen ORDER BY species_id ASC;"
).fetchall()
dex_captured_rows = cur.execute(
    "SELECT species_id, last_encounter_id FROM dex_captured ORDER BY species_id ASC;"
).fetchall()
dex_seen_species = {row[0] for row in dex_seen_rows}
dex_captured_species = {row[0] for row in dex_captured_rows}

threshold_event_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'encounter_threshold_crossed';"
).fetchone()[0]
field_selected_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'field_selected';"
).fetchone()[0]
rarity_selected_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'rarity_selected';"
).fetchone()[0]
species_selected_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'species_selected';"
).fetchone()[0]
encounter_spawned_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'encounter_spawned';"
).fetchone()[0]
capture_resolved_rows = cur.execute(
    """
    SELECT aggregate_id, payload_json
    FROM domain_events
    WHERE event_type = 'capture_resolved'
    ORDER BY domain_event_row_id ASC;
    """
).fetchall()
capture_resolved_event_count = len(capture_resolved_rows)
seen_dex_updated_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'seen_dex_updated';"
).fetchone()[0]
captured_dex_updated_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'captured_dex_updated';"
).fetchone()[0]
domain_event_count = cur.execute("SELECT COUNT(*) FROM domain_events;").fetchone()[0]
state_total_encounters, state_total_captures = cur.execute(
    "SELECT total_encounters, total_captures FROM exploration_state WHERE exploration_state_id = 1;"
).fetchone()

field_matches_species = 1
capture_probability_matches_rarity = 1
capture_roll_in_range = 1
outcome_matches_roll = 1
encounter_threshold_sequence_matches = 1

for expected_index, encounter in enumerate(encounters, start=1):
    (
        _encounter_id,
        encounter_sequence,
        threshold_event_index,
        species_id,
        field_code,
        rarity_tier,
        capture_probability,
        capture_roll,
        outcome,
    ) = encounter

    species_row = cur.execute(
        "SELECT field_code, rarity_tier FROM species WHERE species_id = ? LIMIT 1;",
        (species_id,),
    ).fetchone()
    if species_row is None:
        field_matches_species = 0
    else:
        species_field, species_rarity = species_row
        if field_code != species_field or rarity_tier != species_rarity:
            field_matches_species = 0

    expected_probability = expected_probabilities.get(rarity_tier)
    if expected_probability is None or not math.isclose(
        capture_probability, expected_probability, rel_tol=0, abs_tol=1e-12
    ):
        capture_probability_matches_rarity = 0

    if not (0.0 <= capture_roll < 1.0):
        capture_roll_in_range = 0

    expected_outcome = "captured" if capture_roll < capture_probability else "escaped"
    if outcome != expected_outcome:
        outcome_matches_roll = 0

    if encounter_sequence != expected_index or threshold_event_index != expected_index:
        encounter_threshold_sequence_matches = 0

capture_resolved_payload_matches = 1
if capture_resolved_event_count != encounter_count:
    capture_resolved_payload_matches = 0
else:
    for aggregate_id, payload_json in capture_resolved_rows:
        encounter = encounter_by_id.get(aggregate_id)
        if encounter is None:
            capture_resolved_payload_matches = 0
            break

        try:
            payload = json.loads(payload_json)
        except json.JSONDecodeError:
            capture_resolved_payload_matches = 0
            break

        (
            encounter_id,
            _encounter_sequence,
            _threshold_event_index,
            species_id,
            _field_code,
            rarity_tier,
            capture_probability,
            capture_roll,
            outcome,
        ) = encounter

        if (
            payload.get("encounter_id") != encounter_id
            or payload.get("species_id") != species_id
            or payload.get("rarity") != rarity_tier
            or not math.isclose(payload.get("capture_probability", -1), capture_probability, rel_tol=0, abs_tol=1e-12)
            or not math.isclose(payload.get("rng_roll", -1), capture_roll, rel_tol=0, abs_tol=1e-12)
            or payload.get("outcome") != outcome
        ):
            capture_resolved_payload_matches = 0
            break

print(f"encounter_count={encounter_count}")
print(f"dex_seen_count={len(dex_seen_rows)}")
print(f"dex_captured_count={len(dex_captured_rows)}")
print(f"captured_count={captured_count}")
print(f"threshold_event_count={threshold_event_count}")
print(f"field_selected_count={field_selected_count}")
print(f"rarity_selected_count={rarity_selected_count}")
print(f"species_selected_count={species_selected_count}")
print(f"encounter_spawned_count={encounter_spawned_count}")
print(f"capture_resolved_event_count={capture_resolved_event_count}")
print(f"seen_dex_updated_count={seen_dex_updated_count}")
print(f"captured_dex_updated_count={captured_dex_updated_count}")
print(f"domain_event_count={domain_event_count}")
print(f"state_total_encounters={state_total_encounters}")
print(f"state_total_captures={state_total_captures}")
print(f"threshold_event_count_matches_expected={int(threshold_event_count == expected_threshold_count)}")
print(f"field_selected_count_matches_expected={int(field_selected_count == expected_threshold_count)}")
print(f"rarity_selected_count_matches_expected={int(rarity_selected_count == expected_threshold_count)}")
print(f"species_selected_count_matches_expected={int(species_selected_count == expected_threshold_count)}")
print(f"encounter_spawned_count_matches_expected={int(encounter_spawned_count == expected_threshold_count)}")
print(f"capture_resolved_matches_encounter_count={int(capture_resolved_event_count == encounter_count)}")
print(f"seen_dex_updated_matches_encounter_count={int(seen_dex_updated_count == encounter_count)}")
print(f"captured_dex_updated_matches_captured_count={int(captured_dex_updated_count == captured_count)}")
print(f"domain_event_count_matches_expected={int(domain_event_count == 2 + threshold_event_count + field_selected_count + rarity_selected_count + species_selected_count + encounter_spawned_count + capture_resolved_event_count + seen_dex_updated_count + captured_dex_updated_count)}")
print(f"dex_seen_matches_unique_encounter_species={int(dex_seen_species == encounter_species)}")
print(f"dex_captured_matches_unique_captured_species={int(dex_captured_species == captured_species)}")
print(f"state_total_captures_matches_captured_count={int(state_total_captures == captured_count)}")
print(f"dex_seen_links_valid={int(all(last_encounter_id in encounter_by_id for _, last_encounter_id in dex_seen_rows))}")
print(f"dex_captured_links_valid={int(all(last_encounter_id in encounter_by_id for _, last_encounter_id in dex_captured_rows))}")
print(f"field_matches_species={field_matches_species}")
print(f"capture_probability_matches_rarity={capture_probability_matches_rarity}")
print(f"capture_roll_in_range={capture_roll_in_range}")
print(f"outcome_matches_roll={outcome_matches_roll}")
print(f"capture_resolved_payload_matches={capture_resolved_payload_matches}")
print(f"encounter_threshold_sequence_matches={encounter_threshold_sequence_matches}")
PY
}

probe_backfill_lane() {
  local database_path="$1"
  local provider_code="$2"
  python3 - "$database_path" "$provider_code" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
provider_code = sys.argv[2]
db = sqlite3.connect(db_path)
cur = db.cursor()

backfill_started_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'backfill_started';"
).fetchone()[0]
backfill_completed_count = cur.execute(
    "SELECT COUNT(*) FROM domain_events WHERE event_type = 'backfill_completed';"
).fetchone()[0]
latest_backfill = cur.execute(
    """
    SELECT status,
           samples_examined,
           samples_created,
           duplicates_skipped,
           errors_count
    FROM backfill_runs
    WHERE provider_code = ?
    ORDER BY backfill_run_id DESC
    LIMIT 1;
    """,
    (provider_code,),
).fetchone()
health = cur.execute(
    """
    SELECT source_mode, health_state
    FROM provider_health
    WHERE provider_code = ?
    ORDER BY provider_health_id DESC
    LIMIT 1;
    """,
    (provider_code,),
).fetchone()

print(f"backfill_started_count={backfill_started_count}")
print(f"backfill_completed_count={backfill_completed_count}")
if latest_backfill is None:
    print("latest_backfill_status=none")
    print("latest_samples_examined=0")
    print("latest_samples_created=0")
    print("latest_duplicates_skipped=0")
    print("latest_errors_count=0")
else:
    print(f"latest_backfill_status={latest_backfill[0]}")
    print(f"latest_samples_examined={latest_backfill[1]}")
    print(f"latest_samples_created={latest_backfill[2]}")
    print(f"latest_duplicates_skipped={latest_backfill[3]}")
    print(f"latest_errors_count={latest_backfill[4]}")

if health is None:
    print("latest_health_source_mode=none")
    print("latest_health_state=none")
else:
    print(f"latest_health_source_mode={health[0]}")
    print(f"latest_health_state={health[1]}")
PY
}

set_gameplay_started_at() {
  local database_path="$1"
  local started_at="${2:-2026-04-01T00:00:00Z}"
  sqlite3 "$database_path" <<SQL
INSERT INTO settings (setting_key, setting_value_json, updated_at)
VALUES ('gameplay_started_at', '"$started_at"', '$started_at')
ON CONFLICT(setting_key) DO UPDATE SET
  setting_value_json = excluded.setting_value_json,
  updated_at = excluded.updated_at;
SQL
}

set_live_gameplay_started_at() {
  local database_path="$1"
  local started_at="${2:-2026-04-01T00:00:00Z}"
  sqlite3 "$database_path" <<SQL
INSERT INTO settings (setting_key, setting_value_json, updated_at)
VALUES ('live_gameplay_started_at', '"$started_at"', '$started_at')
ON CONFLICT(setting_key) DO UPDATE SET
  setting_value_json = excluded.setting_value_json,
  updated_at = excluded.updated_at;
SQL
}

printf 'VERIFY INFO: root=%s\n' "$ROOT"
printf 'VERIFY INFO: worker=%s\n' "$worker_tag"
printf 'VERIFY INFO: scratch=%s\n' "$scratch_path"
printf 'VERIFY INFO: include_release_tooling=%s\n' "$include_release_tooling"
printf 'VERIFY INFO: include_readme_screenshots=%s\n' "$include_readme_screenshots"

build_started_at="$(timing_now)"
set +e
build_output="$(swift_cmd build 2>&1)"
build_status=$?
set -e
if (( build_status != 0 )); then
  printf '%s\n' "$build_output"
  printf 'VERIFY FAIL: swift build exited with status %s\n' "$build_status" >&2
  exit "$build_status"
fi
tokenmon_app_bin_dir="$(swift_cmd build --show-bin-path)"
tokenmon_app_bin="$tokenmon_app_bin_dir/TokenmonApp"
[[ -x "$tokenmon_app_bin" ]] || { printf 'VERIFY FAIL: missing built TokenmonApp at %s\n' "$tokenmon_app_bin" >&2; exit 1; }
printf 'VERIFY PASS: swift build\n'
printf '%s\n' "$build_output"
record_timing "build" "swift_build" "$build_started_at"

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

workflow_assets_started_at="$(timing_now)"
if [[ "$has_species_art_tooling" == "1" ]]; then
  art_manifest_output="$("$ROOT/scripts/sync-species-art-manifest" 2>&1)"
  require_contains "$art_manifest_output" "base_approved=151"
  require_contains "$art_manifest_output" "not_started=0"
  printf 'VERIFY PASS: species art manifest sync\n'

  art_export_output="$("$ROOT/scripts/build-species-animation-assets" 2>&1)"
  require_contains "$art_export_output" "manual_species_exports=151"
  printf 'VERIFY PASS: species animation asset export\n'

  art_export_probe="$(python3 - "$ROOT/assets/sprites/species" <<'PY'
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
species_dirs = [path for path in root.iterdir() if path.is_dir()]
portrait = sum(1 for path in species_dirs if (path / "portrait_32.png").exists())
portrait64 = sum(1 for path in species_dirs if (path / "portrait_64.png").exists())
idle = sum(1 for path in species_dirs if (path / "companion_idle_16.png").exists())
roam = sum(1 for path in species_dirs if (path / "companion_roam_16.png").exists())
spawn = sum(1 for path in species_dirs if (path / "spawn_32.png").exists())
spawn64 = sum(1 for path in species_dirs if (path / "spawn_64.png").exists())
resolve_success = sum(1 for path in species_dirs if (path / "resolve_success_32.png").exists())
resolve_success64 = sum(1 for path in species_dirs if (path / "resolve_success_64.png").exists())
resolve_escape = sum(1 for path in species_dirs if (path / "resolve_escape_32.png").exists())
resolve_escape64 = sum(1 for path in species_dirs if (path / "resolve_escape_64.png").exists())
print(f"species_dirs={len(species_dirs)}")
print(f"portrait_exports={portrait}")
print(f"portrait_64_exports={portrait64}")
print(f"obsolete_companion_exports={idle + roam}")
print(f"spawn_exports={spawn}")
print(f"spawn_64_exports={spawn64}")
print(f"resolve_success_exports={resolve_success}")
print(f"resolve_success_64_exports={resolve_success64}")
print(f"resolve_escape_exports={resolve_escape}")
print(f"resolve_escape_64_exports={resolve_escape64}")
PY
)"
  require_contains "$art_export_probe" "species_dirs=151"
  require_contains "$art_export_probe" "portrait_exports=151"
  require_contains "$art_export_probe" "portrait_64_exports=151"
  require_contains "$art_export_probe" "obsolete_companion_exports=0"
  require_contains "$art_export_probe" "spawn_exports=151"
  require_contains "$art_export_probe" "spawn_64_exports=151"
  require_contains "$art_export_probe" "resolve_success_exports=151"
  require_contains "$art_export_probe" "resolve_success_64_exports=151"
  require_contains "$art_export_probe" "resolve_escape_exports=151"
  require_contains "$art_export_probe" "resolve_escape_64_exports=151"
  printf 'VERIFY PASS: species art export completeness\n'

