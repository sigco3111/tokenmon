fi

if [[ "$include_readme_screenshots" == "1" ]]; then
  marketing_assets_started_at="$(timing_now)"
  readme_screenshot_dir="$tmpdir/readme-screens"
  readme_variant_dir="$readme_screenshot_dir/variants"
  readme_screenshot_output="$(TOKENMON_APP_BIN="$tokenmon_app_bin" "$ROOT/scripts/capture-readme-screenshots" --allow-menu-bar-skip --output-dir "$readme_screenshot_dir" 2>&1)"
  require_contains "$readme_screenshot_output" "screenshots_output=$readme_screenshot_dir"
  require_contains "$readme_screenshot_output" "variant_screenshots_root=$readme_variant_dir"
  require_contains "$readme_screenshot_output" "now_tab: $readme_screenshot_dir/now-tab.png"
  require_contains "$readme_screenshot_output" "tokens_tab: $readme_screenshot_dir/tokens-tab.png"
  require_contains "$readme_screenshot_output" "stats_tab: $readme_screenshot_dir/stats-tab.png"
  require_contains "$readme_screenshot_output" "dex_capture_mode: actual_window"
  require_contains "$readme_screenshot_output" "settings_capture_mode: actual_window"
  if printf '%s' "$readme_screenshot_output" | grep -Fq "popover_capture_mode: hosted_borderless_window"; then
    :
  elif printf '%s' "$readme_screenshot_output" | grep -Fq "popover_capture_mode: actual_status_item_popover"; then
    :
  else
    printf 'VERIFY FAIL: unsupported popover capture mode for readme screenshots\n' >&2
    exit 1
  fi
  [[ -f "$readme_screenshot_dir/menu-overview.png" ]] || { printf 'VERIFY FAIL: missing menu screenshot\n' >&2; exit 1; }
  [[ -f "$readme_screenshot_dir/now-tab.png" ]] || { printf 'VERIFY FAIL: missing now-tab screenshot\n' >&2; exit 1; }
  [[ -f "$readme_screenshot_dir/tokens-tab.png" ]] || { printf 'VERIFY FAIL: missing tokens-tab screenshot\n' >&2; exit 1; }
  [[ -f "$readme_screenshot_dir/stats-tab.png" ]] || { printf 'VERIFY FAIL: missing stats-tab screenshot\n' >&2; exit 1; }
  [[ -f "$readme_screenshot_dir/seen-dex.png" ]] || { printf 'VERIFY FAIL: missing seen dex screenshot\n' >&2; exit 1; }
  [[ -f "$readme_screenshot_dir/settings.png" ]] || { printf 'VERIFY FAIL: missing settings screenshot\n' >&2; exit 1; }
  for language in english korean; do
    for appearance in dark light; do
      for asset in menu-hero.gif menu-overview.png now-tab.png tokens-tab.png stats-tab.png seen-dex.png settings.png; do
        [[ -f "$readme_variant_dir/$language/$appearance/$asset" ]] || {
          printf 'VERIFY FAIL: missing readme screenshot variant %s/%s/%s\n' "$language" "$appearance" "$asset" >&2
          exit 1
        }
      done
    done
  done
  grep -Fq "assets/screenshots/variants/english/dark/menu-hero.gif" README.md || {
    printf 'VERIFY FAIL: README.md missing english screenshot path\n' >&2
    exit 1
  }
  grep -Fq "assets/screenshots/variants/english/dark/menu-overview.png" README.md || {
    printf 'VERIFY FAIL: README.md missing english menu screenshot path\n' >&2
    exit 1
  }
  grep -Fq "assets/screenshots/variants/korean/dark/menu-hero.gif" README.ko.md || {
    printf 'VERIFY FAIL: README.ko.md missing korean screenshot path\n' >&2
    exit 1
  }
  grep -Fq "assets/screenshots/variants/korean/dark/menu-overview.png" README.ko.md || {
    printf 'VERIFY FAIL: README.ko.md missing korean menu screenshot path\n' >&2
    exit 1
  }
  if printf '%s' "$readme_screenshot_output" | grep -Fq "menu_bar_capture_status: skipped"; then
    require_contains "$readme_screenshot_output" "menu_bar_capture_reason:"
  else
    require_contains "$readme_screenshot_output" "menu_bar_capture_mode: actual_status_item"
    require_contains "$readme_screenshot_output" "menu_bar_capture_status: captured"
    require_contains "$readme_screenshot_output" "hero_gif: $readme_screenshot_dir/menu-hero.gif"
    [[ -f "$readme_screenshot_dir/menu-hero.gif" ]] || { printf 'VERIFY FAIL: missing menu hero GIF\n' >&2; exit 1; }
  fi
  printf 'VERIFY PASS: readme media generation\n'
  record_timing "marketing_assets" "readme_screenshots" "$marketing_assets_started_at"
fi

