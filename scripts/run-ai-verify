printf '%s\n' '{"event_type":"provider_usage_sample","provider":"codex","source_mode":"codex_exec_json","provider_session_id":"thread_partial","observed_at":"2026-04-04T00:03:00Z","workspace_dir":"/tmp/tokenmon-fixture","model_slug":"gpt-5.4","transcript_path":null,"total_input_tokens":1000,"total_output_tokens":500,"total_cached_input_tokens":0,"normalized_total_tokens":1500,"provider_event_fingerprint":"codex:thread_partial:turn_001","raw_reference":{"kind":"jsonl","offset":"1","event_name":"turn.completed"}}' > "$partial_inbox"
