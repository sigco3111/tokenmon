#!/bin/sh
printf '%s\n' '{"type":"thread.started","thread_id":"thread_stream_verify","cwd":"/tmp/tokenmon-stream","model":"gpt-5.4"}'
sleep 0.2
printf '%s\n' '{"type":"turn.completed","thread_id":"thread_stream_verify","turn_id":"turn_001","timestamp":"2026-04-06T00:00:00Z","cwd":"/tmp/tokenmon-stream","model":"gpt-5.4","usage":{"input_tokens":1000,"cached_input_tokens":100,"output_tokens":400}}'
sleep 0.4
printf '%s\n' '{"type":"turn.completed","thread_id":"thread_stream_verify","turn_id":"turn_002","timestamp":"2026-04-06T00:00:03Z","cwd":"/tmp/tokenmon-stream","model":"gpt-5.4","usage":{"input_tokens":1200,"cached_input_tokens":0,"output_tokens":500}}'
SH
