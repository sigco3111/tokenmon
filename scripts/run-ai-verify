  require_contains "$multi_threshold_probe" "capture_resolved_payload_matches=1"
  require_contains "$multi_threshold_probe" "encounter_threshold_sequence_matches=1"
  printf 'VERIFY PASS: multi-threshold encounter resolution invariants\n'
fi

multi_threshold_status_output="$(tokenmon_app_cmd --tokenmon-status --db "$multi_threshold_db" 2>&1)"
require_contains "$multi_threshold_status_output" "recent_encounters: $(probe_value "$multi_threshold_cli_probe" recent_encounters)"
require_contains "$multi_threshold_status_output" "total_encounters: $(probe_value "$multi_threshold_cli_probe" total_encounters)"
printf 'VERIFY PASS: multi-threshold status recency count\n'

